% Redefine section mark to include the § symbol in the header
\renewcommand{\sectionmark}[1]{\markboth{§\,\thesection\quad#1}{}}

% Section styling
\titleformat{\section}
  {\normalfont\Large\titlefont\bfseries\color{accentdark}}
  {}{0pt}
  {§\,\thesection\quad}
  [\vspace{0.3em}{\color{rulecolor}\titlerule[1pt]}]

\titleformat{\subsection}
  {\normalfont\large\titlefont\bfseries\color{accent}}
  {§\,\thesubsection}{0.6em}{}

\titleformat{\subsubsection}
  {\normalfont\normalsize\titlefont\bfseries\color{accent!85!black}}
  {§\,\thesubsubsection}{0.5em}{}

\titlespacing*{\section}{0pt}{1.2em}{0.4em}
\titlespacing*{\subsection}{0pt}{0.4em}{-0.2em}
\titlespacing*{\subsubsection}{0pt}{0.4em}{-0.2em}



