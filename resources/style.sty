% ==============================================================================
%                              Counters
% ==============================================================================
\newcounter{theoremctr}[section]
\newcounter{definitionctr}[section]
\newcounter{lemmactr}[section]
\newcounter{propositionctr}[section]
\newcounter{corollaryctr}[section]
\newcounter{notectr}[section]
\newcounter{problemctr}[section]
\newcounter{resultctr}[section]
\newcounter{postulatectr}[section]

\renewcommand{\thetheoremctr}{\thesection.\arabic{theoremctr}}
\renewcommand{\thedefinitionctr}{\thesection.\arabic{definitionctr}}
\renewcommand{\thelemmactr}{\thesection.\arabic{lemmactr}}
\renewcommand{\thepropositionctr}{\thesection.\arabic{propositionctr}}
\renewcommand{\thecorollaryctr}{\thesection.\arabic{corollaryctr}}
\renewcommand{\thenotectr}{\thesection.\arabic{notectr}}
\renewcommand{\theproblemctr}{\thesection.\arabic{problemctr}}
\renewcommand{\theresultctr}{\thesection.\arabic{resultctr}}
\renewcommand{\thepostulatectr}{\thesection.\arabic{postulatectr}}

\numberwithin{equation}{section}

% ==============================================================================
%                              Theorem Environments
% ==============================================================================
\newtcolorbox{thmbox}[1][]{mythm, title={#1}}
\newtcolorbox{defbox}[1][]{mydef, title={#1}}
\newtcolorbox{notbox}[1][]{mynote, title={#1}}
\newtcolorbox{proofbox}[1][]{myproof, #1}

% Theorem
\newenvironment{theorem}[1][\theoremname]{%
  \refstepcounter{theoremctr}%
  \begin{thmbox}[#1 \thetheoremctr.]\itshape
}{\end{thmbox}}

% Lemma
\newenvironment{lemma}[1][\lemmaname]{%
  \refstepcounter{lemmactr}%
  \begin{thmbox}[#1 \thelemmactr.]\itshape
}{\end{thmbox}}

% Proposition
\newenvironment{proposition}[1][\propositionname]{%
  \refstepcounter{propositionctr}%
  \begin{thmbox}[#1 \thepropositionctr.]\itshape
}{\end{thmbox}}

% Corollary
\newenvironment{corollary}[1][\corollaryname]{%
  \refstepcounter{corollaryctr}%
  \begin{thmbox}[#1 \thecorollaryctr.]\itshape
}{\end{thmbox}}

% Result
\newenvironment{result}[1][\resultname]{%
  \refstepcounter{resultctr}%
  \begin{thmbox}[#1 \theresultctr.]\itshape
}{\end{thmbox}}

% Definition
\newenvironment{definition}[1][\definitionname]{%
  \refstepcounter{definitionctr}%
  \begin{defbox}[#1 \thedefinitionctr.]
}{\end{defbox}}

% Postulate
\newenvironment{postulate}[1][\postulatename]{%
  \refstepcounter{postulatectr}%
  \begin{defbox}[#1 \thepostulatectr.]
}{\end{defbox}}

% Note
\newenvironment{note}[1][\notename]{%
  \refstepcounter{notectr}%
  \begin{notbox}[#1 \thenotectr.]
}{\end{notbox}}

% Problem
\newtcolorbox{probbox}[1][]{myproblem, title={#1}}

\newenvironment{problem}[1][\problemname]{%
  \refstepcounter{problemctr}%
  \begin{probbox}[#1 \theproblemctr.]
}{\end{probbox}}

% Starred versions
\newenvironment{theorem*}[1][\theoremname]{\begin{thmbox}[#1.]\itshape}{\end{thmbox}}
\newenvironment{lemma*}[1][\lemmaname]{\begin{thmbox}[#1.]\itshape}{\end{thmbox}}
\newenvironment{definition*}[1][\definitionname]{\begin{defbox}[#1.]}{\end{defbox}}
\newenvironment{note*}[1][\notename]{\begin{notbox}[#1.]}{\end{notbox}}
\newenvironment{problem*}[1][\problemname]{\begin{probbox}[#1.]}{\end{probbox}}

% ==============================================================================
%                              Proof Environment
% ==============================================================================
\newtcolorbox{solutionbox}[1][]{mysolution, #1}

\renewenvironment{proof}[1][\proofenvname]{%
  \begin{proofbox}%
    {\titlefont\itshape\color{thmline}#1.}\enspace\ignorespaces
}{%
    \par\nopagebreak\vspace{0.3em}\hfill{\small\itshape\color{thmline}\proofended}\par
  \end{proofbox}%
}

\newenvironment{solution}[1][\solutionname]{%
  \begin{solutionbox}%
    {\titlefont\itshape\color{probline}#1.}\enspace\ignorespaces
}{%
    \par\nopagebreak\vspace{0.3em}\hfill{\small\itshape\color{probline}\solutionended}\par
  \end{solutionbox}%
}

% Overview box for section summaries
\newtcolorbox{overviewbox}[1][]{
  enhanced,
  boxrule=0pt,
  leftrule=3pt,
  rightrule=0pt,
  toprule=1.5pt,
  bottomrule=1.5pt,
  arc=0pt,
  outer arc=0pt,
  colframe=accent,
  interior style={left color=accent!5, right color=white},
  title={\overviewname},
  coltitle=accentdark,
  fonttitle=\bfseries\sffamily,
  attach boxed title to top left={yshift=-\tcboxedtitleheight/2, xshift=5mm},
  boxed title style={
    colback=accent!5,
    frame hidden,
  },
  after skip=0pt,
  #1
}

\newtcolorbox{termsbox}[1][]{
  enhanced,
  breakable,
  boxrule=0pt,
  leftrule=3pt,
  rightrule=0pt,
  toprule=1.5pt,
  bottomrule=1.5pt,
  arc=0pt,
  outer arc=0pt,
  colframe=accent,
  interior style={left color=accent!5, right color=white},
  title={\termsname},
  coltitle=accentdark,
  fonttitle=\bfseries\sffamily,
  attach boxed title to top right={yshift=-\tcboxedtitleheight/2, xshift=-5mm},
  boxed title style={
    colback=white,
    frame hidden,
  },
  top=4pt,
  % borderline north removed for solid top rule matching bottom
  before skip=0pt,
  #1
}

% Figure box style - "Floating Card" with Pop
\newtcolorbox{figurebox}[1][]{
  enhanced,
  boxrule=0pt,
  frame hidden,
  colback=white,
  borderline west={3pt}{0pt}{figline},
  arc=0pt,
  % Spacing
  left=15pt,
  right=15pt,
  top=10pt,
  bottom=10pt,
  before skip=0pt,
  after skip=0pt,
  #1
}


