\definecolor{titleblue}{HTML}{5a9bd4}
\definecolor{titledark}{HTML}{2c5282}

% Custom title page with geometric design
% Usage: \maketitlepage{Title}{Subtitle}{Author}{Date}
\newcommand{\maketitlepage}[4]{%
  \thispagestyle{empty}%
  \begin{tikzpicture}[remember picture, overlay]
    % Full light blue background (extended to avoid gaps)
    \fill[titleblue] ([xshift=-2mm,yshift=-2mm]current page.south west) rectangle ([xshift=2mm,yshift=2mm]current page.north east);
    
    % Subtle darker corner accent - bottom left
    \fill[titledark] 
      (current page.south west) -- 
      ([yshift=8cm]current page.south west) -- 
      ([xshift=8cm]current page.south west) -- cycle;
      
    % Thin white geometric lines
    \draw[white, line width=1.5pt] 
      ([xshift=3cm, yshift=3cm]current page.south west) -- 
      ([xshift=3cm, yshift=12cm]current page.south west) --
      ([xshift=12cm, yshift=3cm]current page.south west) -- cycle;

    % Small circle accent (top vertex of the white triangle)
    \fill[white] ([xshift=3cm, yshift=12cm]current page.south west) circle (5pt);

    % Title Content - aligned exactly 3cm from the right edge
    \node[anchor=north east, inner sep=0pt] 
      at ([xshift=-3cm, yshift=-4cm]current page.north east) {
        \begin{minipage}{15cm}
          \raggedleft
          % Optical alignment: larger fonts have larger sidebearings, so we nudge it right slightly
          {\fontsize{72}{84}\selectfont\titlefont\bfseries\color{white}#1\hspace*{-0.04em}\par}
          \vspace{1.2cm}
          {\fontsize{36}{42}\selectfont\titlefont\color{white!90}#2\par}
          \vspace{3cm}
          {\fontsize{20}{24}\selectfont\color{white!80}\bfseries#3\par}
          \vspace{0.5cm}
          {\fontsize{16}{20}\selectfont\color{white!70}#4\par}
        \end{minipage}
    };
  \end{tikzpicture}%
  \newpage
  \setcounter{page}{1}%
}

