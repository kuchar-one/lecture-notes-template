\RequirePackage[perpage, symbol*]{footmisc}

% Custom footnote symbols matching Landau style ( *, †, ‡, §, ¶, ||, **, ††, ‡‡ )
\DefineFNsymbols{landau}{{\ensuremath\ast}{\ensuremath\dagger}{\ensuremath\ddagger}{\ensuremath\mathsection}{\ensuremath\mathparagraph}{\ensuremath\|}{\ensuremath{\ast\ast}}{\ensuremath{\dagger\dagger}}{\ensuremath{\ddagger\ddagger}}}
\setfnsymbol{landau}
\AtBeginDocument{\renewcommand{\thefootnote}{\fnsymbol{footnote}}}

% Stylish footnote formatting
\renewcommand{\footnoterule}{%
  \kern -3pt
    {\color{thmline}\hrule width 2in height 0.4pt}
  \kern 2.6pt
}

\makeatletter
\renewcommand\@makefntext[1]{%
  \parindent 1em%
  \noindent
  \hb@xt@1.8em{\hss\color{accent}\@thefnmark\,}\hspace{0.2em}#1}
\makeatother
